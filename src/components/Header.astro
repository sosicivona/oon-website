---
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;

const navItems = [
  { label: "Start Here", href: link("start-here/") },
  { label: "Read", href: link("read/") },
  { label: "Themes", href: link("themes/") },
  { label: "Evidence & Questions", href: link("evidence-questions/") },
  { label: "Watch", href: link("watch/") },
  { label: "Sources", href: `${basePath}#sources` },
  { label: "About", href: link("about/") },
];
---

<header class="site-header">
  <a class="brand" href={basePath} aria-label="Oyagaa-Oomo Network home">
    <span>Oyagaa-Oomo Network</span>
  </a>
  <div class="header-actions">
    <nav class="site-nav" aria-label="Primary navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to light theme">
      Light
    </button>
  </div>
</header>
