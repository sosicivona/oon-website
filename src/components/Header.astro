---
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;

const navItems = [
  { label: "Start", href: link("start-here/") },
  { label: "Read", href: link("read/") },
  { label: "Timeline", href: link("timeline/") },
  { label: "Sources", href: link("sources/") },
];

const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="brand" href={basePath} aria-label="Oyagaa-Oomo Network home">
      <span>Oyagaa-Oomo Network</span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      {navItems.map((item) => {
        const isCurrent = currentPath === item.href;
        return <a href={item.href} aria-current={isCurrent ? "page" : undefined}>{item.label}</a>;
      })}
    </nav>
  </div>
</header>
