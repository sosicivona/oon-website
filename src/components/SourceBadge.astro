---
const {
  label = "Source boundary",
  explanation,
} = Astro.props;

const defaultExplanation =
  "Source text, translation, summary, analysis, hypothesis, and OON interpretation are kept separate. Missing source details stay marked as pending review.";
---

<div class="source-boundary-note">
  <span>{label}</span>
  <p>{explanation ?? defaultExplanation}</p>
</div>
