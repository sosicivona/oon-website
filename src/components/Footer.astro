---
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<footer class="site-footer">
  <div>
    <p class="footer-title">Oyagaa-Oomo Network</p>
    <p>A reading-first interface for entering the UMMO dossier and returning to source paths.</p>
  </div>
  <div class="footer-link-groups">
    <nav aria-label="Support footer navigation">
      <a href={link("about/")}>About OON</a>
      <a href={link("start-here/#faq")}>FAQ</a>
      <a href={link("source-continuity/")}>Source Continuity</a>
      <a href={link("watch/")}>Watch / Public Channels</a>
    </nav>
  </div>
</footer>
