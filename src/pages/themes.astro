---
import InfoPanel from "../components/InfoPanel.astro";
import Section from "../components/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Topics | Oyagaa-Oomo Network"
  description="Provisional topic pathways for reading the UMMO source material."
>
  <Section
    eyebrow="Topics"
    title="A browse mode inside Read."
    lede="Topics help readers follow repeated subjects across the corpus while keeping source material and interpretation separate."
    variant="page-hero"
  >
    <div class="card-grid">
      <InfoPanel title="Placeholder topic pathway" text="Topic relationships will appear only after source review." />
      <InfoPanel title="Placeholder period pathway" text="Chronology will stay cautious when source dates are uncertain." />
      <InfoPanel title="Placeholder type pathway" text="Material type labels remain separate from source-status labels." />
    </div>
  </Section>
</BaseLayout>
