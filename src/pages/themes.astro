---
import Section from "../components/Section.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Topics | Oyagaa-Oomo Network"
  description="Provisional topic pathways for reading the UMMO/OOMO source material."
>
  <Section
    eyebrow="Topics"
    title="A browse mode inside Read."
    lede="Topics help readers follow repeated subjects across the corpus while keeping source material and interpretation separate."
    variant="page-hero"
  >
    <div class="card-grid">
      <ThemeCard title="Identity and appearance" text="Provisional pathway for source-linked material." />
      <ThemeCard title="Culture and social structure" text="Provisional pathway for related communications and descriptions." />
      <ThemeCard title="Humanity and Earth" text="Provisional pathway for material concerning human life and Earth." />
      <ThemeCard title="Science and technology" text="Provisional pathway for technical material held for source review and comparison." />
      <ThemeCard title="Philosophy and social organization" text="Provisional pathway for ideas read in context before analysis." />
      <ThemeCard title="Other civilizations" text="Provisional pathway for claims and descriptions kept separate from assessment." />
    </div>
  </Section>
</BaseLayout>
