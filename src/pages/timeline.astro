---
import BoundaryCallout from "../components/BoundaryCallout.astro";
import Section from "../components/Section.astro";
import TimelineSpine from "../components/TimelineSpine.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const events = [
  {
    type: "Orientation point",
    date: "Date pending review",
    title: "Placeholder chronology entry",
    text: "A future event summary will appear only after source and date review.",
    status: "Chronology pending review",
  },
  {
    type: "Source review point",
    date: "Date pending review",
    title: "Placeholder source-path checkpoint",
    text: "Source references, archive paths, and classification notes remain separated from interpretation.",
    status: "Source path pending review",
  },
  {
    type: "Translation review point",
    date: "Date pending review",
    title: "Placeholder language-layer checkpoint",
    text: "Original language, translation availability, and public translation labels should be visible when reviewed.",
    status: "Translation status pending review",
  },
];
---

<BaseLayout
  title="Timeline | Oyagaa-Oomo Network"
  description="A cautious chronological skeleton for the UMMO dossier."
>
  <Section
    eyebrow="Timeline"
    title="Chronology without false certainty."
    lede="Timeline will show reviewed events and source-path checkpoints. Until then, uncertainty is part of the interface."
    variant="page-hero"
  >
    <TimelineSpine events={events} />
    <BoundaryCallout
      label="Timeline safety"
      text="Exact dates, event ordering, relationship claims, and source summaries must come from reviewed records, not visual placeholders."
    />
  </Section>
</BaseLayout>
