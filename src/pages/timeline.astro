---
import Section from "../components/Section.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const phases = [
  {
    label: "Communication received",
    title: "Early correspondence and calls",
    text: "Early material is approached as communications and related records requiring source-path and chronology review.",
  },
  {
    label: "Researcher / archive event",
    title: "Receiver networks and circulation",
    text: "The dossier moves through receivers, researchers, copies, classifications, and archive work.",
  },
  {
    label: "Researcher / archive event",
    title: "Archive growth",
    text: "Archive and research communities preserve, compare, translate, and organize the expanding material.",
  },
  {
    label: "Public / media event",
    title: "Peña authorship crisis",
    text: "José Luis Jordán Peña's authorship claim becomes a central explanation to treat seriously within the wider dossier history.",
  },
  {
    label: "Researcher / archive event",
    title: "Research and classification period",
    text: "Researchers continue classification, comparison, source tracking, translation, and interpretation work.",
  },
  {
    label: "Source-continuity event",
    title: "NR, GR1, and later communications",
    text: "Later communication-chain material is handled with cautious labels and source-continuity notes.",
  },
  {
    label: "Source-continuity event",
    title: "Twitter and source-account period",
    text: "Later public-account material requires explicit source-status language and careful separation from assessment.",
  },
  {
    label: "OON / public orientation event",
    title: "OON public orientation",
    text: "OON provides a reading interface, public orientation, and pathways back to archives and source chains.",
  },
  {
    label: "Public / media event",
    title: "Current disclosure-context relevance",
    text: "The dossier may be read in relation to wider public conversations, without making disclosure the homepage thesis.",
  },
];
---

<BaseLayout
  title="Timeline | Oyagaa-Oomo Network"
  description="A cautious chronological skeleton for the UMMO/OOMO dossier."
>
  <Section
    eyebrow="Timeline"
    title="The chronological skeleton."
    lede="Timeline gives readers the arc before they enter details. It does not resolve authorship, origin, interpretation, or source-continuity questions."
    variant="page-hero"
  >
    <div class="card-grid">
      {phases.map((phase) => (
        <ThemeCard title={phase.title} text={phase.text} meta={phase.label} />
      ))}
    </div>
  </Section>
</BaseLayout>
