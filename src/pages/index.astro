---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Oyagaa-Oomo Network | Evidence-first dossier entry"
  description="An evidence-first prototype homepage for the Oyagaa-Oomo Network website."
>
  <header class="site-header">
    <a class="brand" href="#top" aria-label="Oyagaa-Oomo Network home">
      <span class="brand-name">Oyagaa-Oomo Network</span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      <a href="#read">Read</a>
      <a href="#watch">Watch</a>
      <a href="#evidence">Evidence</a>
      <a href="#archives">Archives</a>
      <a href="#method">About</a>
    </nav>
  </header>

  <section
    id="top"
    class="hero"
    aria-labelledby="page-title"
  >
    <div
      class="hero-backdrop"
      style={`background-image: linear-gradient(180deg, rgba(3, 7, 18, 0.32), rgba(3, 7, 18, 0.68) 46%, rgba(3, 7, 18, 0.96)), radial-gradient(circle at 50% 38%, rgba(3, 7, 18, 0.04), rgba(3, 7, 18, 0.54) 62%), url("${import.meta.env.BASE_URL}images/oon-banner-v3.jpg")`}
      aria-hidden="true"
    ></div>
    <div class="section-shell hero-shell">
      <div class="hero-inner glass-panel">
        <p class="eyebrow">Source-first research network</p>
        <h1 id="page-title">A documented UFO dossier spanning decades.</h1>
        <p class="hero-subtitle">
          Letters, scans, translations, technical claims, anomalies, and competing explanations —
          organized for examination, not belief.
        </p>
        <div class="cta-row" aria-label="Homepage actions">
          <a class="button button-primary" href="#evidence">See the evidence</a>
          <a class="button button-secondary" href="#read">Read one letter</a>
          <a class="button button-ghost" href="#archives">Verify sources</a>
        </div>
      </div>
    </div>
  </section>

  <section id="evidence" class="section-shell evidence-section" aria-labelledby="examination-title">
    <div class="section-heading">
      <p class="eyebrow">Why it deserves examination</p>
    </div>
    <div class="compact-grid">
      <article class="info-card">
        <h2 id="examination-title">Documented corpus</h2>
        <p>Letters, scans, references, translations.</p>
      </article>
      <article class="info-card">
        <h2>Long timeline</h2>
        <p>A multi-decade body of material.</p>
      </article>
      <article class="info-card">
        <h2>Technical claims</h2>
        <p>Physics, biology, cosmology, social systems.</p>
      </article>
      <article class="info-card">
        <h2>Anomalies</h2>
        <p>Claims and patterns to test.</p>
      </article>
      <article class="info-card">
        <h2>Counterarguments</h2>
        <p>Hoax, literary, social, intelligence, anomalous.</p>
      </article>
    </div>
    <div class="evidence-mini">
      <p>Strong claims are mapped with source status, competing explanations, and confidence levels.</p>
      <a class="button button-secondary" href="#evidence">Explore Evidence &amp; Questions</a>
    </div>
  </section>

  <section id="read" class="section-shell letter-section" aria-labelledby="letter-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Read the letters</p>
        <h2 id="letter-title">Enter through one letter.</h2>
      </div>
      <p>
        A guided first reading path will pair one verified text with context, status, and archive links.
      </p>
    </div>
    <article class="featured-card">
      <dl class="source-list">
        <div>
          <dt>Reference</dt>
          <dd>TODO</dd>
        </div>
        <div>
          <dt>Theme</dt>
          <dd>TODO</dd>
        </div>
        <div>
          <dt>Why this text matters</dt>
          <dd>TODO</dd>
        </div>
        <div>
          <dt>Source status</dt>
          <dd>TODO</dd>
        </div>
        <div>
          <dt>Available languages</dt>
          <dd>TODO</dd>
        </div>
      </dl>
      <div class="card-actions">
        <a class="button button-primary" href="#read">Read this text</a>
        <a class="text-link" href="#archives">View archive source</a>
      </div>
    </article>
  </section>

  <section id="watch" class="section-shell watch-section" aria-labelledby="watch-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Watch</p>
        <h2 id="watch-title">Watch the dossier unfold.</h2>
      </div>
      <p>
        OON videos provide a visual and audio entry point into the case while the website
        organizes sources, reading paths, and evidence mapping.
      </p>
    </div>
    <div class="watch-grid">
      <article class="info-card glass-card">
        <h3>OON YouTube</h3>
        <p>TODO: Add verified channel link.</p>
      </article>
      <article class="info-card glass-card">
        <h3>Podcast / visual explainers</h3>
        <p>TODO: Add verified media pathway.</p>
      </article>
    </div>
  </section>

  <section class="section-shell" aria-labelledby="entry-title">
    <div class="section-heading">
      <p id="entry-title" class="eyebrow">Choose your entry</p>
    </div>
    <div class="path-grid">
      <a class="path-card" href="#read">
        <span>Read</span>
        <p>One essential text.</p>
      </a>
      <a class="path-card" href="#watch">
        <span>Watch</span>
        <p>OON video entry points.</p>
      </a>
      <a class="path-card" href="#evidence">
        <span>Evidence</span>
        <p>Claims, anomalies, counterarguments.</p>
      </a>
      <a class="path-card" href="#archives">
        <span>Archives</span>
        <p>Sources and references.</p>
      </a>
    </div>
  </section>

  <section id="about" class="section-shell method-section" aria-labelledby="about-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">About OON</p>
        <h2 id="about-title">A source-first research network.</h2>
      </div>
      <p>
        Oyagaa-Oomo Network is a human, international group studying, organizing, and
        sharing material around the OOMO/UMMO dossier. The website provides structured
        access; the network continues the discussion through public channels.
      </p>
    </div>
    <ul class="method-strip">
      <li>No belief required</li>
      <li>Source first</li>
      <li>Translation visible</li>
      <li>Analysis labeled</li>
      <li>Archives linked</li>
    </ul>
  </section>

  <section
    id="archives"
    class="section-shell ecosystem-section"
    aria-labelledby="ecosystem-title"
  >
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Source ecosystem</p>
        <h2 id="ecosystem-title">Where the documents live.</h2>
      </div>
      <p>
        The website organizes and contextualizes material that remains linked to its source archives.
      </p>
    </div>
    <div
      class="ecosystem-list"
      style={`background-image: linear-gradient(rgba(3, 7, 18, 0.88), rgba(3, 7, 18, 0.92)), url("${import.meta.env.BASE_URL}images/oon-banner-v3.jpg")`}
    >
      <article class="source-row">
        <p>Primary archive</p>
        <h3>UMMO-Ciencias</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>French archive</p>
        <h3>Ummo-Sciences FR</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>English access</p>
        <h3>Ummo-Sciences EN</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>Reference wiki</p>
        <h3>UmmoWiki</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>Living discussion</p>
        <h3>OON X / Twitter</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>Video layer</p>
        <h3>OON YouTube</h3>
        <span>TODO</span>
      </article>
    </div>
  </section>

  <footer class="site-footer">
    <p>Oyagaa-Oomo Network</p>
    <p>Prototype homepage. Verified sources, links, and reading paths will be added later.</p>
  </footer>
</BaseLayout>
