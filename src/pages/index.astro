---
import Section from "../components/Section.astro";
import SourceBadge from "../components/SourceBadge.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL;
const link = (path) => `${basePath}${path}`;
const bannerImage = `${basePath}images/oon-banner-v3.jpg`;
---

<BaseLayout
  title="Oyagaa-Oomo Network | Reading the UMMO/OOMO dossier"
  description="A reading-first beta website for the Oyagaa-Oomo Network and the UMMO/OOMO correspondence dossier."
>
  <section class="hero-beta" aria-labelledby="page-title">
    <div
      class="hero-beta-image"
      style={`background-image: linear-gradient(90deg, rgba(250, 247, 239, 0.96), rgba(250, 247, 239, 0.78) 46%, rgba(250, 247, 239, 0.2)), url("${bannerImage}")`}
      aria-hidden="true"
    ></div>
    <div class="hero-beta-content">
      <p class="eyebrow">Reading-first beta</p>
      <h1 id="page-title">
        For sixty years, letters have arrived from a civilization claiming to come from
        another world.
      </h1>
      <p class="hero-quote">
        They did not ask us to believe them. They asked to be read, doubted, and thought
        about freely.
      </p>
      <a class="button button-primary" href={link("start-here/")}>Start reading</a>
    </div>
  </section>

  <Section
    id="begin"
    eyebrow="Begin with the letters"
    title="Read before deciding."
    lede="The beta starts with reading paths, short context notes, and source-status language. The reader stays free to compare, question, and move slowly."
  >
    <div class="two-column">
      <ThemeCard
        title="Start Here"
        text="A calm orientation to what the corpus is, how this site reads it, and what remains open."
        href={link("start-here/")}
        meta="First step"
      />
      <ThemeCard
        title="Read"
        text="A placeholder reading path for historical letters, later communications, source status, and archive links."
        href={link("read/")}
        meta="Corpus entry"
      />
    </div>
  </Section>

  <Section
    id="themes"
    eyebrow="Explore the themes"
    title="A worldview appears through repeated topics."
    lede="The corpus describes identities, culture, humanity, technology, social organization, and other civilizations. Beta theme pages keep these as topic pathways, not conclusions."
  >
    <div class="card-grid">
      <ThemeCard title="Worldview" text="Claims and descriptions to read across the corpus." href={link("themes/")} />
      <ThemeCard title="Humanity and Earth" text="Topic pathway for source-linked reading." href={link("themes/")} />
      <ThemeCard title="Science and technology" text="Technical claims held for comparison and source review." href={link("themes/")} />
    </div>
  </Section>

  <Section
    id="evidence"
    eyebrow="Evidence & Questions"
    title="Questions stay visible."
    lede="Evidence work belongs beside the reading experience. Items remain placeholders until source chains, chronology, and assessments are reviewed."
  >
    <div class="status-grid">
      <article>
        <span>Source located</span>
        <h3>Document record</h3>
        <p>Placeholder for source-linked material.</p>
      </article>
      <article>
        <span>Chronology under review</span>
        <h3>Sequence question</h3>
        <p>Placeholder for timeline comparison.</p>
      </article>
      <article>
        <span>Assessment pending</span>
        <h3>Competing reading</h3>
        <p>Placeholder for counterarguments and open questions.</p>
      </article>
    </div>
    <a class="text-link" href={link("evidence-questions/")}>Open Evidence & Questions</a>
  </Section>

  <Section
    id="source-continuity"
    eyebrow="Source Continuity"
    title="The source chain matters."
    lede="Each future reader page should make source account, archive location, translation status, and analysis boundaries visible."
    variant="soft-panel"
  >
    <SourceBadge />
    <a class="text-link" href={link("source-continuity/")}>Review source-status language</a>
  </Section>

  <Section
    id="watch"
    eyebrow="Watch OON"
    title="Video can orient; reading remains central."
    lede="OON videos and visual explainers can introduce the case while the website keeps source review and reading paths visible."
  >
    <div class="two-column">
      <ThemeCard title="OON YouTube" text="Curated channel link pending." href={link("watch/")} />
      <ThemeCard title="Visual explainers" text="Selected media pathway pending." href={link("watch/")} />
    </div>
  </Section>

  <Section
    id="sources"
    eyebrow="Sources / Archives"
    title="Where the reading points back."
    lede="The beta links toward source archives and public OON channels without replacing them."
  >
    <div class="source-list">
      <article><span>Primary archive</span><strong>UMMO-Ciencias</strong><em>To verify</em></article>
      <article><span>French archive</span><strong>Ummo-Sciences FR</strong><em>To verify</em></article>
      <article><span>English access</span><strong>Ummo-Sciences EN</strong><em>To verify</em></article>
      <article><span>Reference wiki</span><strong>UmmoWiki</strong><em>To verify</em></article>
      <article><span>Living discussion</span><strong>OON X / Twitter</strong><em>Link pending</em></article>
      <article><span>Video layer</span><strong>OON YouTube</strong><em>Link pending</em></article>
    </div>
  </Section>
</BaseLayout>
