---
import Section from "../components/Section.astro";
import BoundaryCallout from "../components/BoundaryCallout.astro";
import NavTile from "../components/NavTile.astro";
import SourceBoundaryNote from "../components/SourceBoundaryNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
const bannerImage = `${basePath}images/oon-banner-v3.jpg`;
---

<BaseLayout
  title="Oyagaa-Oomo Network | Reading the UMMO dossier"
  description="A reading-first website for the Oyagaa-Oomo Network and the UMMO dossier."
>
  <section class="hero-beta" aria-labelledby="page-title">
    <div
      class="hero-beta-image"
      style={`background-image: linear-gradient(90deg, rgba(243, 240, 233, 0.9), rgba(243, 240, 233, 0.7) 48%, rgba(243, 240, 233, 0.28)), url("${bannerImage}")`}
      aria-hidden="true"
    ></div>
    <div class="hero-beta-content">
      <p class="eyebrow">Oyagaa-Oomo Network</p>
      <h1 id="page-title">A calm reading interface for the UMMO dossier.</h1>
      <p class="hero-quote">
        Start with orientation, move into source-linked metadata, and keep every layer
        of reading separate from interpretation.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={link("start-here/")}>Start here</a>
        <a class="button button-secondary" href={link("read/")}>Read</a>
      </div>
    </div>
  </section>

  <Section
    id="begin"
    eyebrow="Continue"
    title="Choose a path."
    lede="The launch navigation stays small: orient first, enter the material, follow chronology, then verify source paths."
  >
    <div class="card-grid compact">
      <NavTile
        title="Start"
        text="Get the shape of the project before entering source records."
        href={link("start-here/")}
        meta="Orient"
      />
      <NavTile
        title="Read"
        text="Browse placeholder communication rows and source-layer structure."
        href={link("read/")}
        meta="Source material"
      />
      <NavTile
        title="Timeline"
        text="See a cautious chronology structure with uncertainty visible."
        href={link("timeline/")}
        meta="Chronology"
      />
      <NavTile
        title="Sources"
        text="Understand how source paths will be shown after review."
        href={link("sources/")}
        meta="Verification"
      />
    </div>
    <div class="stacked-notes">
      <SourceBoundaryNote />
      <BoundaryCallout
        label="Content safety"
        text="This visual pass does not add real corpus content, quotes, dates, document IDs, or external archive links."
      />
    </div>
  </Section>
</BaseLayout>
