---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const bannerImage = `${basePath}images/oon-banner-v3.jpg`;
---

<BaseLayout
  title="Oyagaa-Oomo Network | Evidence-first dossier entry"
  description="An evidence-first prototype homepage for the Oyagaa-Oomo Network website."
>
  <header class="site-header">
    <a class="brand" href="#top" aria-label="Oyagaa-Oomo Network home">
      <span class="brand-name">Oyagaa-Oomo Network</span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      <a href="#read">Read</a>
      <a href="#watch">Watch</a>
      <a href="#case">Evidence</a>
      <a href="#archives">Archives</a>
      <a href="#about">About</a>
    </nav>
  </header>

  <section
    id="top"
    class="hero"
    aria-labelledby="page-title"
  >
    <div
      class="hero-backdrop"
      style={`background-image: linear-gradient(180deg, rgba(3, 7, 18, 0.32), rgba(3, 7, 18, 0.68) 46%, rgba(3, 7, 18, 0.96)), radial-gradient(circle at 50% 38%, rgba(3, 7, 18, 0.04), rgba(3, 7, 18, 0.54) 62%), url("${bannerImage}")`}
      aria-hidden="true"
    ></div>
    <div class="section-shell hero-shell">
      <div class="hero-inner glass-panel">
        <p class="eyebrow">Source-first research network</p>
        <h1 id="page-title">The UMMO dossier: decades of letters, claims, and archives.</h1>
        <p class="hero-subtitle">
          A source-first gateway into one of ufology's most unusual correspondence cases —
          from historical letters to later public communications, preserved for examination,
          not belief.
        </p>
        <p class="hero-identity">
          Oyagaa-Oomo Network is a human, international group organizing the case into
          clearer reading paths, evidence maps, videos, and archive access.
        </p>
        <div class="cta-row" aria-label="Homepage actions">
          <a class="button button-primary" href="#case">Understand the case</a>
          <a class="button button-secondary" href="#case">See the evidence</a>
          <a class="button button-ghost" href="#read">Read the correspondence</a>
        </div>
      </div>
    </div>
  </section>

  <section id="case" class="section-shell case-section" aria-labelledby="case-title">
    <div class="section-heading">
      <p class="eyebrow">The case</p>
      <h2 id="case-title">What makes UMMO different?</h2>
    </div>
    <div class="compact-grid">
      <article class="info-card">
        <h3>Correspondence, not sightings</h3>
        <p>Letters, later communications, and documents rather than a single visual event.</p>
      </article>
      <article class="info-card">
        <h3>Long timeline</h3>
        <p>Material, analysis, and archives spanning decades.</p>
      </article>
      <article class="info-card">
        <h3>Technical content</h3>
        <p>Scientific, social, philosophical, and cosmological claims to examine.</p>
      </article>
      <article class="info-card">
        <h3>Public archives</h3>
        <p>Preserved through Spanish, French, and international research efforts.</p>
      </article>
      <article class="info-card">
        <h3>Anomalies to examine</h3>
        <p>Claims and patterns that can be mapped, tested, or challenged.</p>
      </article>
      <article class="info-card">
        <h3>Counterarguments included</h3>
        <p>Hoax, literary, social, intelligence, and anomalous explanations remain in view.</p>
      </article>
    </div>
  </section>

  <section id="read" class="section-shell letter-section" aria-labelledby="letter-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Read the correspondence</p>
        <h2 id="letter-title">Enter the corpus.</h2>
      </div>
      <p>
        Reading paths will connect historical letters, later communications, context,
        source status, and archive links.
      </p>
    </div>
    <article class="featured-card">
      <div class="featured-heading">
        <p class="eyebrow">Featured entry point</p>
      </div>
      <dl class="source-list">
        <div>
          <dt>Reference</dt>
          <dd>TODO</dd>
        </div>
        <div>
          <dt>Corpus type</dt>
          <dd>Letter / later communication / archive item — TODO</dd>
        </div>
        <div>
          <dt>Theme</dt>
          <dd>TODO</dd>
        </div>
        <div>
          <dt>Why this matters</dt>
          <dd>TODO</dd>
        </div>
        <div>
          <dt>Source status</dt>
          <dd>TODO</dd>
        </div>
        <div>
          <dt>Available languages</dt>
          <dd>TODO</dd>
        </div>
      </dl>
      <div class="card-actions">
        <a class="button button-primary" href="#read">Read in context</a>
        <a class="text-link" href="#archives">View archive source</a>
      </div>
    </article>
  </section>

  <section class="section-shell route-section" aria-labelledby="entry-title">
    <div class="section-heading">
      <h2 id="entry-title">Continue by path</h2>
    </div>
    <div class="path-grid">
      <a class="path-card" href="#watch">
        <span>Watch</span>
        <p>OON video and audio entry points.</p>
      </a>
      <a class="path-card" href="#case">
        <span>Evidence</span>
        <p>Claims, anomalies, and counterarguments.</p>
      </a>
      <a class="path-card" href="#archives">
        <span>Archives</span>
        <p>Sources, references, and document access.</p>
      </a>
    </div>
  </section>

  <section id="watch" class="section-shell watch-section" aria-labelledby="watch-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Watch</p>
        <h2 id="watch-title">Watch the dossier unfold.</h2>
      </div>
      <p>
        OON videos provide a visual entry into the case while the website organizes
        sources, reading paths, and evidence mapping.
      </p>
    </div>
    <div class="watch-grid">
      <article class="info-card glass-card">
        <h3>OON YouTube</h3>
        <p>TODO: Add verified channel link.</p>
      </article>
      <article class="info-card glass-card">
        <h3>Podcast / visual explainers</h3>
        <p>TODO: Add verified media pathway.</p>
      </article>
    </div>
  </section>

  <section id="about" class="section-shell method-section" aria-labelledby="about-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">About OON</p>
        <h2 id="about-title">A source-first research network.</h2>
      </div>
      <p>
        Oyagaa-Oomo Network is a human, international group studying and sharing material
        around the OOMO/UMMO dossier. The website provides structure, reading paths,
        evidence mapping, and archive access; the public channels continue the discussion.
      </p>
    </div>
    <ul class="method-strip">
      <li>No belief required</li>
      <li>Source first</li>
      <li>Translation visible</li>
      <li>Analysis labeled</li>
      <li>Archives linked</li>
    </ul>
  </section>

  <section
    id="archives"
    class="section-shell ecosystem-section"
    aria-labelledby="ecosystem-title"
  >
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Source ecosystem</p>
        <h2 id="ecosystem-title">Where the documents live.</h2>
      </div>
      <p>
        The website organizes and contextualizes material that remains linked to its source archives.
      </p>
    </div>
    <div
      class="ecosystem-list"
      style={`background-image: linear-gradient(rgba(3, 7, 18, 0.88), rgba(3, 7, 18, 0.92)), url("${bannerImage}")`}
    >
      <article class="source-row">
        <p>Primary archive</p>
        <h3>UMMO-Ciencias</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>French archive</p>
        <h3>Ummo-Sciences FR</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>English access</p>
        <h3>Ummo-Sciences EN</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>Reference wiki</p>
        <h3>UmmoWiki</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>Living discussion</p>
        <h3>OON X / Twitter</h3>
        <span>TODO</span>
      </article>
      <article class="source-row">
        <p>Video layer</p>
        <h3>OON YouTube</h3>
        <span>TODO</span>
      </article>
    </div>
  </section>

  <footer class="site-footer">
    <p>Oyagaa-Oomo Network</p>
    <p>Prototype homepage. Verified sources, links, and reading paths will be added later.</p>
  </footer>
</BaseLayout>
