---
import Section from "../components/Section.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
const bannerImage = `${basePath}images/oon-banner-v3.jpg`;
---

<BaseLayout
  title="Oyagaa-Oomo Network | Reading the UMMO dossier"
  description="A reading-first website for the Oyagaa-Oomo Network and the UMMO dossier."
>
  <section class="hero-beta" aria-labelledby="page-title">
    <div
      class="hero-beta-image"
      style={`background-image: linear-gradient(90deg, rgba(250, 247, 239, 0.96), rgba(250, 247, 239, 0.78) 46%, rgba(250, 247, 239, 0.2)), url("${bannerImage}")`}
      aria-hidden="true"
    ></div>
    <div class="hero-beta-content">
      <p class="eyebrow">The UMMO dossier</p>
      <h1 id="page-title">
        For sixty years, a stream of letters, reports, and recorded contact has been
        preserved, studied, and debated.
      </h1>
      <p class="hero-quote">
        This site helps readers enter the material, follow its threads, and trace it back
        to the archives.
      </p>
      <a class="button button-primary" href={link("start-here/")}>Start here</a>
    </div>
  </section>

  <Section
    id="begin"
    eyebrow="Continue"
    title="Choose a path."
  >
    <div class="card-grid compact">
      <ThemeCard
        title="Read"
        text="Enter through one communication, one topic, one period, or one source path."
        href={link("read/")}
        meta="Source material"
      />
      <ThemeCard
        title="Timeline"
        text="See the high-level arc before entering document-level detail."
        href={link("timeline/")}
        meta="Chronology"
      />
      <ThemeCard
        title="Sources"
        text="Return to archive paths, public channels, and source-status notes."
        href={link("sources/")}
        meta="Verification"
      />
    </div>
  </Section>
</BaseLayout>
