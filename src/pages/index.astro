---
import Section from "../components/Section.astro";
import SourceBadge from "../components/SourceBadge.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
const bannerImage = `${basePath}images/oon-banner-v3.jpg`;
---

<BaseLayout
  title="Oyagaa-Oomo Network | Reading the UMMO/OOMO dossier"
  description="A reading-first website for the Oyagaa-Oomo Network and the UMMO/OOMO correspondence dossier."
>
  <section class="hero-beta" aria-labelledby="page-title">
    <div
      class="hero-beta-image"
      style={`background-image: linear-gradient(180deg, rgba(7, 17, 31, 0.08), rgba(7, 17, 31, 0.24) 52%, rgba(7, 17, 31, 0.66)), radial-gradient(circle at 58% 42%, rgba(7, 17, 31, 0), rgba(7, 17, 31, 0.18) 68%), url("${bannerImage}")`}
      aria-hidden="true"
    ></div>
    <div class="hero-beta-content">
      <div class="hero-panel">
        <p class="eyebrow">The UMMO/OOMO dossier</p>
        <h1 id="page-title">
          For sixty years, letters have arrived from a civilization claiming to come from
          another world.
        </h1>
        <p class="hero-quote">
          They did not ask us to believe them. They asked to be read, doubted, and thought
          about freely.
        </p>
        <a class="button button-primary" href={link("start-here/")}>Start reading</a>
      </div>
    </div>
  </section>

  <Section
    id="begin"
    eyebrow="Begin with the letters"
    title="Read before deciding."
    lede="Start with the correspondence itself, then move outward to themes, source chains, archives, and open questions."
  >
    <div class="two-column">
      <ThemeCard
        title="Start Here"
        text="A calm orientation to the dossier, the source material, and how this site approaches uncertainty."
        href={link("start-here/")}
        meta="First step"
      />
      <ThemeCard
        title="Read"
        text="A guided entry point into historical letters, later communications, archive references, and source-status notes."
        href={link("read/")}
        meta="Corpus entry"
      />
    </div>
  </Section>

  <Section
    id="themes"
    eyebrow="Explore the themes"
    title="A worldview appears through repeated topics."
    lede="The corpus returns again and again to identity, Earth, science, society, consciousness, other civilizations, and the ethics of contact."
  >
    <div class="card-grid">
      <ThemeCard title="Worldview" text="Claims and descriptions to read across the corpus." href={link("themes/")} />
      <ThemeCard title="Humanity and Earth" text="Topic pathway for source-linked reading." href={link("themes/")} />
      <ThemeCard title="Science and technology" text="Technical claims held for comparison and source review." href={link("themes/")} />
    </div>
  </Section>

  <Section
    id="evidence"
    eyebrow="Evidence & Questions"
    title="Questions stay visible."
    lede="Some items invite comparison with history, science, or later events. They are presented as cases to examine, not as conclusions."
  >
    <div class="status-grid">
      <article>
        <span>To analyze</span>
        <h3>Mathematical cases</h3>
        <p>Technical or scientific material that requires source-chain review and expert comparison.</p>
      </article>
      <article>
        <span>Chronology under review</span>
        <h3>Chronology cases</h3>
        <p>Sequences where dates, context, and later events need to be read carefully.</p>
      </article>
      <article>
        <span>Open question</span>
        <h3>Counter-readings</h3>
        <p>Alternative explanations and objections remain part of the dossier review.</p>
      </article>
    </div>
    <a class="text-link" href={link("evidence-questions/")}>Open Evidence & Questions</a>
  </Section>

  <Section
    id="source-continuity"
    eyebrow="Source Continuity"
    title="The source chain matters."
    lede="Each page should make the archive location, source status, translation status, and interpretation boundary visible."
    variant="soft-panel"
  >
    <SourceBadge />
    <a class="text-link" href={link("source-continuity/")}>Review source-status language</a>
  </Section>

  <Section
    id="watch"
    eyebrow="Watch OON"
    title="Video can orient. Reading remains central."
    lede="OON videos can introduce the case, while the site keeps the source material, references, and reading paths visible."
  >
    <div class="two-column">
      <ThemeCard title="OON YouTube" text="Watch public episodes and visual explainers." href={link("watch/")} />
      <ThemeCard title="OON on X" text="Follow public updates and discussion threads." href={link("watch/")} />
    </div>
  </Section>

  <Section
    id="sources"
    eyebrow="Sources / Archives"
    title="Where the reading points back."
    lede="This site should guide readers toward archive sources and public OON channels without replacing them."
  >
    <div class="source-list">
      <article><span>Primary archive</span><strong>UMMO-Ciencias</strong><em>Archive</em></article>
      <article><span>French archive</span><strong>Ummo-Sciences FR</strong><em>Archive</em></article>
      <article><span>English access</span><strong>Ummo-Sciences EN</strong><em>Archive</em></article>
      <article><span>Reference wiki</span><strong>UmmoWiki</strong><em>Archive</em></article>
      <article><span>Living discussion</span><strong>OON X / Twitter</strong><em>Public channel</em></article>
      <article><span>Video layer</span><strong>OON YouTube</strong><em>Public channel</em></article>
    </div>
  </Section>
</BaseLayout>
