---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const bannerImage = `${basePath}images/oon-banner-v3.jpg`;
---

<BaseLayout
  title="Oyagaa-Oomo Network | Evidence-first dossier entry"
  description="An evidence-first prototype homepage for the Oyagaa-Oomo Network website."
>
  <header class="site-header">
    <a class="brand" href="#top" aria-label="Oyagaa-Oomo Network home">
      <span class="brand-name">Oyagaa-Oomo Network</span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      <a href="#read">Read</a>
      <a href="#watch">Watch</a>
      <a href="#case">Evidence</a>
      <a href="#archives">Archives</a>
      <a href="#about">About</a>
    </nav>
  </header>

  <section
    id="top"
    class="hero"
    aria-labelledby="page-title"
  >
    <div
      class="hero-backdrop"
      style={`background-image: linear-gradient(180deg, rgba(3, 7, 18, 0.32), rgba(3, 7, 18, 0.68) 46%, rgba(3, 7, 18, 0.96)), radial-gradient(circle at 50% 38%, rgba(3, 7, 18, 0.04), rgba(3, 7, 18, 0.54) 62%), url("${bannerImage}")`}
      aria-hidden="true"
    ></div>
    <div class="section-shell hero-shell">
      <div class="hero-grid">
        <div class="hero-copy glass-panel">
          <p class="eyebrow">OOMO / UMMO · Documentary dossier</p>
          <h1 id="page-title">The UMMO dossier</h1>
          <p class="hero-differentiator">A correspondence case, not a sighting case.</p>
          <p class="hero-subtitle">
            Letters, later communications, technical claims, archives, anomalies, and
            competing explanations — organized for reading, comparison, and source review.
          </p>
          <div class="cta-row" aria-label="Homepage actions">
            <a class="button button-primary" href="#case">Understand the case</a>
            <a class="button button-secondary" href="#case">Examine the evidence</a>
            <a class="button button-ghost" href="#read">Enter the corpus</a>
          </div>
        </div>

        <aside class="corpus-index glass-panel" aria-label="Corpus index preview">
          <div class="document-stack" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <p class="index-kicker">Corpus Index</p>
          <div class="index-section">
            <h2>Document types</h2>
            <ul>
              <li><span>Historical correspondence</span><small>primary material</small></li>
              <li><span>Technical annexes</span><small>attached to letters</small></li>
              <li><span>Later communications</span><small>public-era material</small></li>
              <li><span>Recipient correspondence</span><small>context and responses</small></li>
            </ul>
          </div>
          <div class="index-section">
            <h2>Topic pathways</h2>
            <ul class="topic-list">
              <li>Who they say they are</li>
              <li>Culture and society</li>
              <li>Earth and humanity</li>
              <li>Other civilizations</li>
              <li>Science and technology</li>
              <li>Philosophy and social organization</li>
            </ul>
          </div>
          <div class="index-section">
            <h2>Archive sources</h2>
            <ul>
              <li><span>UMMO-Ciencias</span><small>primary archive</small></li>
              <li><span>Ummo-Sciences FR</span><small>French resource</small></li>
              <li><span>Ummo-Sciences EN</span><small>English access</small></li>
              <li><span>UmmoWiki</span><small>cross-reference index</small></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section id="case" class="section-shell case-section" aria-labelledby="case-title">
    <div class="section-heading">
      <p class="eyebrow">The case</p>
      <h2 id="case-title">Most UFO cases begin with an event. UMMO begins with documents.</h2>
      <p class="section-lede">
        The dossier is explored through correspondence, later communications, topic
        pathways, archive sources, and competing explanations.
      </p>
    </div>
    <div class="chip-grid">
      <article class="topic-chip">
        <h3>Correspondence</h3>
      </article>
      <article class="topic-chip">
        <h3>Duration</h3>
      </article>
      <article class="topic-chip">
        <h3>Technical claims</h3>
      </article>
      <article class="topic-chip">
        <h3>Culture and society</h3>
      </article>
      <article class="topic-chip">
        <h3>Earth relationship</h3>
      </article>
      <article class="topic-chip">
        <h3>Other civilizations</h3>
      </article>
      <article class="topic-chip">
        <h3>Archives</h3>
      </article>
      <article class="topic-chip">
        <h3>Counterarguments</h3>
      </article>
    </div>
    <div class="section-cta">
      <a class="button button-secondary" href="#case">Explore Evidence &amp; Questions</a>
    </div>
  </section>

  <section class="section-shell inside-section" aria-labelledby="inside-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Inside the dossier</p>
        <h2 id="inside-title">A corpus of claims, descriptions, and open questions.</h2>
      </div>
      <p>
        Topic pathways make the material easier to read, compare, and connect back to
        source documents.
      </p>
    </div>
    <div class="inside-grid">
      <article class="inside-card">
        <h3>Identity and appearance</h3>
        <p>Topic pathway — source-linked material to review.</p>
      </article>
      <article class="inside-card">
        <h3>Culture and social structure</h3>
        <p>Claims and descriptions to map against source documents.</p>
      </article>
      <article class="inside-card">
        <h3>Humanity and Earth</h3>
        <p>Topic pathway — source-linked material to review.</p>
      </article>
      <article class="inside-card">
        <h3>Science and technology</h3>
        <p>Claims and descriptions to map against source documents.</p>
      </article>
      <article class="inside-card">
        <h3>Other civilizations</h3>
        <p>Topic pathway — source-linked material to review.</p>
      </article>
      <article class="inside-card">
        <h3>Later communications</h3>
        <p>Claims and descriptions to map against source documents.</p>
      </article>
    </div>
  </section>

  <section id="read" class="section-shell letter-section" aria-labelledby="letter-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Read the correspondence</p>
        <h2 id="letter-title">Enter the corpus.</h2>
      </div>
      <p>
        Reading paths will connect historical letters, later communications, context,
        source status, and archive links.
      </p>
    </div>
    <article class="reader-preview glass-panel">
      <div>
        <p class="eyebrow">Reader page structure</p>
        <h3>Each future reader page will separate source, translation, context, and analysis.</h3>
      </div>
      <ol class="reader-steps">
        <li>Source reference</li>
        <li>Translation status</li>
        <li>Context note</li>
        <li>Text or excerpt</li>
        <li>Archive link</li>
        <li>Related material</li>
      </ol>
      <div class="card-actions">
        <a class="button button-primary" href="#read">Reader structure in progress</a>
        <a class="text-link" href="#archives">View archive sources</a>
      </div>
    </article>
  </section>

  <section id="watch" class="section-shell watch-section" aria-labelledby="watch-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Watch</p>
        <h2 id="watch-title">Watch OON explain the case.</h2>
      </div>
      <p>
        Videos and visual explainers offer an easier entry point while the website
        organizes sources, reading paths, and evidence mapping.
      </p>
    </div>
    <div class="watch-grid">
      <article class="info-card glass-card">
        <h3>OON YouTube</h3>
        <p>Curated channel link pending.</p>
      </article>
      <article class="info-card glass-card">
        <h3>Podcast / visual explainers</h3>
        <p>Selected media pathway pending.</p>
      </article>
    </div>
  </section>

  <section class="section-shell evidence-strip-section" aria-labelledby="evidence-strip-title">
    <div class="evidence-strip glass-panel">
      <p id="evidence-strip-title">
        Claims, anomalies, and counterarguments will be mapped with source status and
        confidence levels.
      </p>
      <a class="button button-secondary" href="#case">Explore Evidence &amp; Questions</a>
    </div>
  </section>

  <section id="about" class="section-shell method-section" aria-labelledby="about-title">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">About OON</p>
        <h2 id="about-title">A human network for source-first study.</h2>
      </div>
      <p>
        Oyagaa-Oomo Network is an international group of independent researchers and
        contributors studying, translating, discussing, and sharing material around the
        OOMO/UMMO dossier.
      </p>
    </div>
    <ul class="method-strip">
      <li>Read carefully</li>
      <li>Compare sources</li>
      <li>Label analysis</li>
      <li>Keep archives visible</li>
      <li>Leave questions open</li>
    </ul>
    <div class="channel-links" aria-label="OON public channels">
      <a class="text-link" href="#archives">X / Twitter</a>
      <a class="text-link" href="#archives">YouTube</a>
    </div>
  </section>

  <section
    id="archives"
    class="section-shell ecosystem-section"
    aria-labelledby="ecosystem-title"
  >
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Source ecosystem</p>
        <h2 id="ecosystem-title">Where the documents live.</h2>
      </div>
      <p>
        The website organizes and contextualizes material that remains linked to source
        archives and public OON channels.
      </p>
    </div>
    <div
      class="ecosystem-list"
      style={`background-image: linear-gradient(rgba(3, 7, 18, 0.88), rgba(3, 7, 18, 0.92)), url("${bannerImage}")`}
    >
      <div class="source-group">
        <h3>Archives</h3>
        <article class="source-row">
          <p>Primary archive</p>
          <h4>UMMO-Ciencias</h4>
          <span>To verify</span>
        </article>
        <article class="source-row">
          <p>French archive</p>
          <h4>Ummo-Sciences FR</h4>
          <span>To verify</span>
        </article>
        <article class="source-row">
          <p>English access</p>
          <h4>Ummo-Sciences EN</h4>
          <span>To verify</span>
        </article>
        <article class="source-row">
          <p>Reference wiki</p>
          <h4>UmmoWiki</h4>
          <span>To verify</span>
        </article>
      </div>
      <div class="source-group">
        <h3>OON channels</h3>
        <article class="source-row">
          <p>Living discussion</p>
          <h4>OON X / Twitter</h4>
          <span>Link pending</span>
        </article>
        <article class="source-row">
          <p>Video layer</p>
          <h4>OON YouTube</h4>
          <span>Link pending</span>
        </article>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <p>Oyagaa-Oomo Network</p>
    <p>Prototype homepage. Verified sources, links, and reading paths will be added later.</p>
  </footer>
</BaseLayout>
