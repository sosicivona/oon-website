---
import Section from "../components/Section.astro";
import SourceBadge from "../components/SourceBadge.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<BaseLayout
  title="Sources | Oyagaa-Oomo Network"
  description="Archive sources, public OON channels, and source-status language for the UMMO/OOMO dossier."
>
  <Section
    eyebrow="Sources / Archives"
    title="Where the reading points back."
    lede="The archive sites remain the true repositories. This website is an interface for entering the dossier, following source chains, and returning to the archives."
    variant="page-hero"
  >
    <div class="card-grid">
      <ThemeCard
        title="UMMO-Ciencias"
        text="Primary archive reference for the Spanish-language corpus and related materials. Link to be verified before public release."
        meta="Primary archive"
      />
      <ThemeCard
        title="Ummo-Sciences FR"
        text="French-language archive and long-running research resource. Link to be verified before public release."
        meta="French archive"
      />
      <ThemeCard
        title="Ummo-Sciences EN"
        text="English access point for selected materials. Link to be verified before public release."
        meta="English access"
      />
      <ThemeCard
        title="UmmoWiki"
        text="Community reference index and cross-reference resource. Link to be verified before public release."
        meta="Reference wiki"
      />
    </div>
  </Section>

  <Section
    eyebrow="Public OON channels"
    title="Where discussion continues."
    lede="Public channels can orient readers and announce new work, while source review stays visible on the site."
  >
    <div class="two-column">
      <ThemeCard
        title="OON public channels"
        text="Public updates, videos, posts, and discussion threads. Links to be verified before public release."
        meta="Public channel"
      />
      <ThemeCard
        title="Source Continuity"
        text="Methodology note for source-chain language, recognized source accounts, translation status, and analysis boundaries."
        href={link("source-continuity/")}
        meta="Methodology"
      />
    </div>
  </Section>

  <Section
    eyebrow="Source-status language"
    title="Archive access is not the same as assessment."
    lede="Source-status notes help separate archive location, communication-chain status, translation status, and interpretation."
    variant="soft-panel"
  >
    <SourceBadge />
    <a class="text-link" href={link("source-continuity/")}>Read the source-continuity note</a>
  </Section>
</BaseLayout>
