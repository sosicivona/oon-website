---
import Section from "../components/Section.astro";
import SourceBadge from "../components/SourceBadge.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<BaseLayout
  title="Sources | Oyagaa-Oomo Network"
  description="Archive sources and source-status language for the UMMO dossier."
>
  <Section
    eyebrow="Sources / Archives"
    title="Where the reading points back."
    lede="The archive sites remain the canonical repositories. This website is an interface for entering the dossier, following source paths, and returning to the archives."
    variant="page-hero"
  >
    <div class="card-grid">
      <ThemeCard
        title="UMMO-Ciencias"
        text="Primary archive reference for the Spanish-language corpus and related materials."
        meta="Primary archive"
      />
      <ThemeCard
        title="Ummo-Sciences FR"
        text="French-language archive and long-running research resource."
        meta="French archive"
      />
      <ThemeCard
        title="Ummo-Sciences EN"
        text="English access point for selected materials."
        meta="English access"
      />
      <ThemeCard
        title="UmmoWiki"
        text="Community reference index and cross-reference resource."
        meta="Reference wiki"
      />
    </div>
  </Section>

  <Section
    eyebrow="Source-status language"
    title="Archive access is not the same as assessment."
    lede="Source-status notes help separate archive location, communication-chain status, translation status, and interpretation."
    variant="soft-panel"
  >
    <SourceBadge />
    <a class="text-link" href={link("source-continuity/")}>Source Continuity</a>
  </Section>
</BaseLayout>
