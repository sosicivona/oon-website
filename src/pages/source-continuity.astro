---
import Section from "../components/Section.astro";
import SourceBadge from "../components/SourceBadge.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<BaseLayout
  title="Source Continuity | Oyagaa-Oomo Network"
  description="Source-status language and source-chain structure for the UMMO dossier."
>
  <Section
    eyebrow="Source Continuity"
    title="Make the source chain visible."
    lede="Some later communications or accounts may be treated by source researchers as source-chain relevant. This does not establish origin; it names how the material is recognized, located, translated, and separated from analysis."
    variant="page-hero"
  >
    <SourceBadge />
    <div class="card-grid">
      <ThemeCard title="Recognized source account" text="A source-status label for material recognized by source researchers as part of a later communication chain." />
      <ThemeCard title="Archive record" text="Where the item can be located or checked." />
      <ThemeCard title="Translation status" text="What language layer the reader is seeing." />
      <ThemeCard title="Analysis boundary" text="Where OON commentary begins." />
    </div>
    <a class="text-link" href={link("sources/")}>View sources</a>
  </Section>
</BaseLayout>
