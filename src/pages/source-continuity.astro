---
import InfoPanel from "../components/InfoPanel.astro";
import Section from "../components/Section.astro";
import SourceBoundaryNote from "../components/SourceBoundaryNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<BaseLayout
  title="Source Continuity | Oyagaa-Oomo Network"
  description="Source-status language and source-chain structure for the UMMO dossier."
>
  <Section
    eyebrow="Source Continuity"
    title="Make the source chain visible."
    lede="Source continuity names how material is located, translated, classified, and separated from analysis. It does not establish origin."
    variant="page-hero"
  >
    <SourceBoundaryNote />
    <div class="card-grid">
      <InfoPanel title="Source path" text="Where an item can be located or checked after review." />
      <InfoPanel title="Source-site classification" text="Inherited classifications stay separate from OON review status." />
      <InfoPanel title="Translation status" text="What language layer the reader is seeing." />
      <InfoPanel title="Analysis boundary" text="Where OON commentary begins." />
    </div>
    <a class="text-link" href={link("sources/")}>View sources</a>
  </Section>
</BaseLayout>
