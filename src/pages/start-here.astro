---
import Section from "../components/Section.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<BaseLayout
  title="Start Here | Oyagaa-Oomo Network"
  description="A calm starting point for reading the UMMO/OOMO correspondence dossier."
>
  <Section
    eyebrow="Start Here"
    title="Begin with the case, then the reading."
    lede="The UMMO/OOMO dossier is the full historical phenomenon. The corpus is the body of letters, messages, and source texts inside it. OON is an interface and network layer, not the source and not the archive."
    variant="page-hero"
  >
    <div class="card-grid">
      <ThemeCard
        title="What the dossier is"
        text="A correspondence and documentary phenomenon made of source texts, archive records, translations, analysis, and contested interpretations."
        href={link("read/")}
      />
      <ThemeCard
        title="What the corpus is"
        text="The letters, messages, and source texts that readers can examine through source status and translation status."
        href={link("read/")}
      />
      <ThemeCard
        title="What OON does"
        text="OON organizes reading paths and context. It does not replace the archives and is not the source."
        href={link("sources/")}
      />
      <ThemeCard
        title="How to read"
        text="Read the corpus first, then compare source chain, translation status, context, and interpretation."
        href={link("source-continuity/")}
      />
      <ThemeCard
        title="What to read first"
        text="Start with correspondence pathways before moving into themes, evidence questions, or public commentary."
        href={link("read/")}
      />
      <ThemeCard
        title="What is not being claimed"
        text="The site does not claim final authority, special access, or a settled interpretation of the dossier."
        href={link("evidence-questions/")}
      />
    </div>
  </Section>

  <Section
    eyebrow="Source status"
    title="Source status is part of the reading."
    lede="Each page should make archive location, communication-chain status, language or translation status, and analysis boundary visible."
  >
    <div class="two-column">
      <ThemeCard title="No acceptance required" text="Source notes do not ask the reader to accept the origin claim." />
      <ThemeCard title="Not a dismissal" text="Open questions remain available for careful comparison and critique." />
    </div>
  </Section>
</BaseLayout>
