---
import Section from "../components/Section.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<BaseLayout
  title="Start Here | Oyagaa-Oomo Network"
  description="A calm starting point for reading the UMMO correspondence dossier."
>
  <Section
    eyebrow="Start"
    title="Begin with the shape of the dossier."
    lede="The UMMO dossier is the wider historical phenomenon. The corpus is the body of letters, communications, reports, notes, and source texts inside it. OON is an interface and network layer, not the source and not the archive."
    variant="page-hero"
  >
    <div class="card-grid">
      <ThemeCard
        title="What is this?"
        text="A long-running documentary and communication dossier made of source material, archive records, translations, analysis, and unresolved questions."
      />
      <ThemeCard
        title="Why is it still studied?"
        text="Researchers continue to compare the scale, structure, source paths, technical range, later communications, and competing interpretations."
        href={link("start-here/#faq")}
      />
      <ThemeCard
        title="What does OON do?"
        text="OON organizes reading paths, source-status language, public orientation, and context while pointing readers back to the archives."
        href={link("about/")}
      />
      <ThemeCard
        title="How can I begin?"
        text="Begin with one communication, one topic, one period, or one source path. The reader does not need to start with everything."
        href={link("read/")}
      />
      <ThemeCard
        title="What this site does — and does not do"
        text="This site does not replace archives, settle authorship, or claim origin."
        href={link("start-here/#faq")}
      />
    </div>
  </Section>

  <Section
    eyebrow="Entry paths"
    title="Choose the question you are actually asking."
  >
    <div class="card-grid compact">
      <ThemeCard title="Understand the arc" text="Use Timeline to see high-level phases before reading details." href={link("timeline/")} />
      <ThemeCard title="Enter the material" text="Use Read to browse by topic, period, type, or source path." href={link("read/")} />
      <ThemeCard title="Trace sources" text="Use Sources to return to archive paths, public channels, and source-status notes." href={link("sources/")} />
    </div>
  </Section>

  <Section
    id="faq"
    eyebrow="FAQ preview"
    title="High-friction questions belong in context."
    variant="soft-panel"
  >
    <div class="two-column">
      <ThemeCard
        title="Why is the dossier still studied after José Luis Jordán Peña's authorship claim?"
        text="That authorship claim is a central explanation and must be treated seriously. It is not the whole history of the dossier. Archive and research communities continued to preserve, classify, and compare the material because of its scale, internal structure, technical range, later communications, and unresolved source-continuity questions."
      />
      <ThemeCard
        title="How should a newcomer read?"
        text="Begin with source paths, chronology, communication type, translation status, and interpretation boundaries before forming a view."
      />
    </div>
  </Section>
</BaseLayout>
