---
import DefinitionList from "../components/DefinitionList.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import InfoPanel from "../components/InfoPanel.astro";
import NavTile from "../components/NavTile.astro";
import Section from "../components/Section.astro";
import SourceBoundaryNote from "../components/SourceBoundaryNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;

const definitions = [
  {
    term: "Source text",
    description: "The source layer itself. This stays separate from translation, summary, analysis, and OON interpretation.",
  },
  {
    term: "Translation",
    description: "A language layer with its own status. Translation is never treated as original source text.",
  },
  {
    term: "Summary",
    description: "A short orientation layer, added only after source review.",
  },
  {
    term: "OON interpretation",
    description: "A clearly labeled reading by OON, kept separate from source material.",
  },
];

const faqs = [
  {
    question: "Do I need to begin with a conclusion?",
    answer: "No. The site is structured so a reader can orient, compare source paths, and leave questions open.",
  },
  {
    question: "Why are placeholders visible?",
    answer: "They mark where the content model will connect after source review. Missing source details are not filled in by guesswork.",
  },
  {
    question: "What should I check first?",
    answer: "Start with the layer you are reading: source text, translation, summary, analysis, hypothesis, or OON interpretation.",
  },
];
---

<BaseLayout
  title="Start Here | Oyagaa-Oomo Network"
  description="A calm starting point for reading the UMMO correspondence dossier."
>
  <Section
    eyebrow="Start"
    title="Begin with the shape of the dossier."
    lede="This page orients the reader before source records appear. It explains the reading layers, the route choices, and what the site does not claim."
    variant="page-hero"
  >
    <SourceBoundaryNote />
    <DefinitionList items={definitions} />
  </Section>

  <Section
    eyebrow="Entry paths"
    title="Choose the task in front of you."
  >
    <div class="card-grid compact">
      <NavTile title="Enter the material" text="Use Read to see the metadata-first row structure." href={link("read/")} />
      <NavTile title="Understand the arc" text="Use Timeline for a cautious chronology scaffold." href={link("timeline/")} />
      <NavTile title="Trace sources" text="Use Sources to see the source-layer model." href={link("sources/")} />
    </div>
    <div class="card-grid compact supporting-grid">
      <InfoPanel title="No belief request" text="The interface should help readers inspect material without asking them to accept a verdict." />
      <InfoPanel title="No invented gaps" text="Unknown dates, links, translations, and statuses remain marked as pending review." />
      <InfoPanel title="Clear layers" text="Source text, translation, summary, analysis, hypothesis, and OON interpretation stay visually separate." />
    </div>
  </Section>

  <Section
    id="faq"
    eyebrow="FAQ"
    title="Questions stay attached to their boundaries."
    variant="soft-panel"
  >
    <FAQAccordion items={faqs} />
  </Section>
</BaseLayout>
