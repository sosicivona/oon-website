---
import Section from "../components/Section.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Watch | Oyagaa-Oomo Network"
  description="OON video and audio entry points for the UMMO/OOMO dossier."
>
  <Section
    eyebrow="Watch"
    title="Video can orient. Reading remains central."
    lede="OON videos can introduce the case, while the site keeps the source material, references, and reading paths visible."
    variant="page-hero"
  >
    <div class="two-column">
      <ThemeCard title="OON YouTube" text="Watch public episodes and visual explainers." />
      <ThemeCard title="OON on X" text="Follow public updates and discussion threads." />
    </div>
  </Section>
</BaseLayout>
