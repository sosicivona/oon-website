---
import Section from "../components/Section.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const youtubeChannelUrl = "https://www.youtube.com/@OYAGAA-OOMO-NETWORK";
---

<BaseLayout
  title="Watch | Oyagaa-Oomo Network"
  description="OON video and audio entry points for the UMMO/OOMO dossier."
>
  <Section
    eyebrow="Watch"
    title="Watch OON explain the case."
    lede="Video can orient the reader. The website keeps source review, reading paths, and open questions visible."
    variant="page-hero"
  >
    <div class="two-column">
      <ThemeCard title="OON YouTube" text="Oyagaa-Oomo Network channel." href={youtubeChannelUrl} />
      <ThemeCard title="Podcast / visual explainers" text="Selected media pathway pending." />
    </div>
  </Section>
</BaseLayout>
