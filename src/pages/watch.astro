---
import InfoPanel from "../components/InfoPanel.astro";
import Section from "../components/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Watch | Oyagaa-Oomo Network"
  description="OON video and public channel entry points for the UMMO dossier."
>
  <Section
    eyebrow="Watch"
    title="OON public channels."
    lede="Video and public updates can orient the reader. The website keeps source review, reading paths, and open questions visible."
    variant="page-hero"
  >
    <div class="two-column">
      <InfoPanel title="Public video placeholder" text="Public channel details will appear only after link and copy review." />
      <InfoPanel title="Public update placeholder" text="External channel links remain pending until verified." />
    </div>
  </Section>
</BaseLayout>
