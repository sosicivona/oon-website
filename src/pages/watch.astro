---
import Section from "../components/Section.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Watch | Oyagaa-Oomo Network"
  description="OON video and public channel entry points for the UMMO dossier."
>
  <Section
    eyebrow="Watch"
    title="OON public channels."
    lede="Video and public updates can orient the reader. The website keeps source review, reading paths, and open questions visible."
    variant="page-hero"
  >
    <div class="two-column">
      <ThemeCard title="OON YouTube" text="Public episodes and visual explainers." />
      <ThemeCard title="OON on X" text="Public updates, posts, and discussion threads." />
    </div>
  </Section>
</BaseLayout>
