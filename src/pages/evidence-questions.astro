---
import Section from "../components/Section.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Evidence & Questions | Oyagaa-Oomo Network"
  description="Neutral evidence questions and open reading paths for the UMMO/OOMO dossier."
>
  <Section
    eyebrow="Evidence & Questions"
    title="Assessment comes after source review."
    lede="Evidence items are read through source chain, chronology, translation status, and competing explanations."
    variant="page-hero"
  >
    <div class="status-grid">
      <article>
        <span>Source located</span>
        <h3>Archive item</h3>
        <p>Source material available for closer reading.</p>
      </article>
      <article>
        <span>To analyze</span>
        <h3>Claim cluster</h3>
        <p>Claims and counter-readings to be separated.</p>
      </article>
      <article>
        <span>Chronology under review</span>
        <h3>Sequence question</h3>
        <p>Dates and order to be checked against source records.</p>
      </article>
      <article>
        <span>Open question</span>
        <h3>Open question</h3>
        <p>Interpretation remains open.</p>
      </article>
    </div>
  </Section>

  <Section
    eyebrow="Future backlog"
    title="Categories for later review."
    lede="These categories stay off the homepage while source chains and assessment boundaries are prepared."
  >
    <div class="card-grid compact">
      <ThemeCard title="Public health claims" text="Category reserved for source-chain review." />
      <ThemeCard title="Geopolitical claims" text="Category reserved for source-chain review." />
      <ThemeCard title="Forecast claims" text="Category reserved for source-chain review." />
      <ThemeCard title="Economic claims" text="Category reserved for source-chain review." />
    </div>
  </Section>
</BaseLayout>
