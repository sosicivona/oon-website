---
import Section from "../components/Section.astro";
import SourceBadge from "../components/SourceBadge.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<BaseLayout
  title="Read | Oyagaa-Oomo Network"
  description="Reading paths for the UMMO/OOMO source material."
>
  <Section
    eyebrow="Read"
    title="Enter the source material."
    lede="The archive record is large. The reader can enter through one communication, one topic, one period, or one source path while source status stays visible."
    variant="page-hero"
  >
    <SourceBadge />
    <div class="reader-preview">
      <div>
        <p class="eyebrow">Reader page anatomy</p>
        <h3>Every future reader page should keep source location, chronology, language, status labels, archive links, context, and OON commentary distinct.</h3>
      </div>
      <ol class="reader-steps">
        <li>Source location</li>
        <li>Date / chronology status</li>
        <li>Language / translation status</li>
        <li>Status labels</li>
        <li>Archive links</li>
        <li>Context note</li>
        <li>Analysis boundary</li>
      </ol>
    </div>
    <a class="text-link" href={link("source-continuity/")}>Read the source-continuity note</a>
  </Section>

  <Section
    eyebrow="Browse modes"
    title="Start small, then widen."
    lede="Read is the main entry point into the corpus and related source material. Topics are a browse mode here, not a top-level launch destination."
  >
    <div class="card-grid">
      <ThemeCard title="By topic" text="A provisional topic mode for following repeated subjects across source material." href={link("themes/")} />
      <ThemeCard title="By period" text="A chronological entry for reading phases of the dossier in context." href={link("timeline/")} />
      <ThemeCard title="By type" text="A way to separate letters, reports, calls, later communications, archive notes, and OON commentary." />
      <ThemeCard title="Essential documents" text="A future curated path for key documents, introduced only after source status is ready." />
      <ThemeCard title="Source path" text="A verification-first route from local reading copy back to archive/source location." href={link("sources/")} />
      <ThemeCard title="Search later" text="A future search mode for locating material without turning the launch site into an archive dump." />
    </div>
  </Section>

  <Section
    eyebrow="Corpus types"
    title="Different materials need visible labels."
    lede="The reader should always know what kind of material they are reading and where interpretation begins."
    variant="soft-panel"
  >
    <div class="card-grid compact">
      <ThemeCard title="Letters" text="Historical correspondence and related source records." />
      <ThemeCard title="Reports" text="Structured source material or records that need source-location and status notes." />
      <ThemeCard title="Phone calls" text="Call-related material treated with chronology and source-path visibility." />
      <ThemeCard title="NR communications" text="Later communication-chain material, labeled cautiously and separately." />
      <ThemeCard title="GR1 communications" text="Later communication-chain material, labeled cautiously and separately." />
      <ThemeCard title="Later accounts / tweets" text="Later public-account material requiring source-continuity notes." />
      <ThemeCard title="Archive notes" text="References, source locations, language status, and contextual notes." />
      <ThemeCard title="OON commentary" text="Analysis and interpretation labeled separately from source material." />
    </div>
  </Section>
</BaseLayout>
