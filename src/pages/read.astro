---
import Section from "../components/Section.astro";
import SourceBadge from "../components/SourceBadge.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<BaseLayout
  title="Read | Oyagaa-Oomo Network"
  description="Reading paths for the UMMO/OOMO correspondence corpus."
>
  <Section
    eyebrow="Read"
    title="Enter through the letters."
    lede="Reading paths will connect historical letters, later communications, context, source status, and archive links."
    variant="page-hero"
  >
    <SourceBadge />
    <div class="reader-preview">
      <div>
        <p class="eyebrow">Reader page structure</p>
        <h3>Each reader page keeps source, translation, context, and analysis distinct.</h3>
      </div>
      <ol class="reader-steps">
        <li>Source reference</li>
        <li>Translation status</li>
        <li>Context note</li>
        <li>Text or excerpt</li>
        <li>Archive link</li>
        <li>Related material</li>
      </ol>
    </div>
    <a class="text-link" href={link("source-continuity/")}>Review source continuity</a>
  </Section>

  <Section
    eyebrow="Reading paths"
    title="Ways into the corpus"
    lede="Reading paths begin with source chain, translation status, and archive context."
  >
    <div class="card-grid">
      <ThemeCard title="Historical letters" text="Enter through source chain, context, and translation status." />
      <ThemeCard title="Later communications" text="Read with source-status notes where applicable." />
      <ThemeCard title="Theme-based reading" text="Topic pathways will connect related passages without forcing conclusions." />
    </div>
  </Section>
</BaseLayout>
