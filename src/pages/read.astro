---
import BoundaryCallout from "../components/BoundaryCallout.astro";
import CommunicationItemRow from "../components/CommunicationItemRow.astro";
import InfoPanel from "../components/InfoPanel.astro";
import Section from "../components/Section.astro";
import SourceLayerPanel from "../components/SourceLayerPanel.astro";
import SourceStatusLabel from "../components/SourceStatusLabel.astro";
import TypeChip from "../components/TypeChip.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;

const sourceLayers = [
  { term: "Source reference", description: "Canonical reference and source path remain pending until verified." },
  { term: "Language layer", description: "Original language and translation availability are shown separately." },
  { term: "Reader status", description: "Onsite reading actions stay hidden until publishing and rights checks pass." },
  { term: "Interpretation", description: "OON interpretation does not appear inside source metadata." },
];

const rows = [
  {
    title: "Placeholder communication item",
    reference: "Canonical reference pending review",
    category: "Communication item",
  },
  {
    title: "Placeholder source record",
    reference: "Source-linked metadata pending review",
    category: "Source record",
  },
  {
    title: "Placeholder translation candidate",
    reference: "Translation basis pending review",
    category: "Translation layer",
  },
];
---

<BaseLayout
  title="Read | Oyagaa-Oomo Network"
  description="Reading paths for the UMMO source material."
>
  <Section
    eyebrow="Read"
    title="Enter the source material."
    lede="Read will become the main entry point into source-linked records. For now it shows the safe row structure and the metadata gates that must be satisfied before publication."
    variant="page-hero"
  >
    <SourceLayerPanel title="Reader page layers" layers={sourceLayers} />
    <a class="text-link" href={link("source-continuity/")}>Read the source-continuity note</a>
  </Section>

  <Section
    eyebrow="Reading paths"
    title="Start with metadata, not claims."
    lede="These path cards describe future browse modes. They do not load real corpus entries yet."
  >
    <div class="card-grid compact">
      <InfoPanel title="By topic" text="Topic tags will appear only after reviewed relationships exist." />
      <InfoPanel title="By period" text="Chronology stays cautious when dates are uncertain or pending." />
      <InfoPanel title="By type" text="Material type is a neutral label, separate from source status." />
    </div>
    <div class="chip-row" aria-label="Placeholder type chips">
      <TypeChip label="Communication item" />
      <TypeChip label="Source record" />
      <TypeChip label="Translation layer" />
    </div>
  </Section>

  <Section
    eyebrow="Metadata rows"
    title="Item rows stay factual and restrained."
    lede="Rows show placeholders for title, reference, type, translation status, and review state. Source excerpts and full reader actions are intentionally absent."
    variant="soft-panel"
  >
    <div class="read-toolbar" aria-label="Read status summary">
      <SourceStatusLabel label="Source-linked metadata pending review" tone="review" />
      <SourceStatusLabel label="Translation status pending review" />
      <SourceStatusLabel label="No source excerpts loaded" />
    </div>
    <div class="communication-list">
      {rows.map((row) => <CommunicationItemRow {...row} />)}
    </div>
    <BoundaryCallout
      label="Empty-state rule"
      text="If a row lacks verified source path, translation state, or publication status, it remains a metadata placeholder rather than a reader page."
    />
  </Section>
</BaseLayout>
