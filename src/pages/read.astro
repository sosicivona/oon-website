---
import Section from "../components/Section.astro";
import SourceBadge from "../components/SourceBadge.astro";
import ThemeCard from "../components/ThemeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${basePath}${path}`;
---

<BaseLayout
  title="Read | Oyagaa-Oomo Network"
  description="Reading paths for the UMMO/OOMO correspondence corpus."
>
  <Section
    eyebrow="Read"
    title="Begin with the correspondence."
    lede="The archive record is large. Readers do not need to begin with everything; they can begin with one letter, one excerpt, or one question while source status stays visible."
    variant="page-hero"
  >
    <SourceBadge />
    <div class="reader-preview">
      <div>
        <p class="eyebrow">Reader page anatomy</p>
        <h3>Every reader page should keep source, translation, context, and analysis distinct.</h3>
      </div>
      <ol class="reader-steps">
        <li>Source location</li>
        <li>Date / chronology status</li>
        <li>Language / translation status</li>
        <li>Status labels</li>
        <li>Archive links</li>
        <li>Context note</li>
      </ol>
    </div>
    <a class="text-link" href={link("source-continuity/")}>Read the source-continuity note</a>
  </Section>

  <Section
    eyebrow="Reading paths"
    title="Ways into the corpus"
    lede="A reading path can begin small, then widen toward document history, later communications, theme pathways, and cases to examine."
  >
    <div class="card-grid">
      <ThemeCard title="Historical letters" text="Classic correspondence read with source chain, language status, and context." />
      <ThemeCard title="Later communications" text="Later attributed communications read with source-status notes where applicable." />
      <ThemeCard title="Theme-based reading" text="Topic pathways will connect related passages without forcing conclusions." />
      <ThemeCard title="Cases to examine" text="Claims and questions can be revisited after the source layer is visible." />
    </div>
  </Section>

  <Section
    eyebrow="Corpus types"
    title="Different materials need different labels."
    lede="The reader should always know what kind of material they are reading and where interpretation begins."
    variant="soft-panel"
  >
    <div class="card-grid compact">
      <ThemeCard title="Classic letters" text="Historical correspondence and related source records." />
      <ThemeCard title="Later communications" text="Recognized source-account material from later communication chains." />
      <ThemeCard title="Archive notes" text="References, source locations, language status, and contextual notes." />
      <ThemeCard title="OON commentary" text="Analysis and interpretation labeled separately from source material." />
    </div>
  </Section>
</BaseLayout>
